{
  "rules": {
    "lobby": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && ((data.exists() && data.child('hostId').val() === auth.uid) || (!data.exists() && newData.child('hostId').val() === auth.uid))"
      }
    },
    "tables": {
      "$code": {
        ".write": "auth != null && (newData.child('public').child('hostId').val() === auth.uid || (data.child('public').exists() && data.child('public').child('hostId').val() === auth.uid))",
        "public": {
          ".read": "auth != null"
        },
        "private": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid"
          }
        },
        "intents": {
          ".read": "auth != null && root.child('tables').child($code).child('public').child('hostId').val() === auth.uid",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "emotes": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
